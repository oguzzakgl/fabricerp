datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                   String                @id @default(uuid()) @db.Uuid
  code                 String
  name                 String
  type                 String                // "CUSTOMER", "SUPPLIER", "BOTH"
  taxOffice            String?               @map("tax_office")
  taxNumber            String?               @map("tax_number")
  phone                String?
  email                String?
  address              String?
  tenantId             String?               @map("tenant_id") @db.Uuid
  tenant               Tenant?               @relation(fields: [tenantId], references: [id])
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  yarnStocks           YarnStock[]
  orders               Order[]
  invoices             Invoice[]
  financialTransactions FinancialTransaction[]

  @@unique([code, tenantId])
  @@map("accounts")
}

model YarnStock {
  id                String              @id @default(uuid()) @db.Uuid
  supplierId        String              @map("supplier_id") @db.Uuid
  supplier          Account             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  yarnType          String              @map("yarn_type")
  neNumber          String?             @map("ne_number")
  color             String
  colorCode         String?             @map("color_code")
  lotNumber         String              @map("lot_number")
  initialKg         Decimal             @map("initial_kg") @db.Decimal(10, 2)
  currentKg         Decimal             @map("current_kg") @db.Decimal(10, 2)
  unitPrice         Decimal             @map("unit_price") @db.Decimal(10, 2)
  tenantId          String?             @map("tenant_id") @db.Uuid
  tenant            Tenant?             @relation(fields: [tenantId], references: [id])
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  warpRecipes       ProductionRecipe[]  @relation("WarpYarn")
  weftRecipes       ProductionRecipe[]  @relation("WeftYarn")

  @@map("yarn_stocks")
}

model Roll {
  id               String            @id @default(uuid()) @db.Uuid
  barcodeNumber    String            @unique @map("barcode_number")
  fabricType       String            @map("fabric_type")
  color            String
  widthCm          Decimal?          @map("width_cm") @db.Decimal(6, 2)
  weightGsm        Decimal?          @map("weight_gsm") @db.Decimal(6, 2)
  lengthM          Decimal           @map("length_m") @db.Decimal(10, 2)
  netWeightKg      Decimal           @map("net_weight_kg") @db.Decimal(10, 2)
  costPrice        Decimal           @map("cost_price") @db.Decimal(10, 2)
  status           String            @default("available") // "available", "reserved", "sold"
  quality          String            @default("1")         // "1", "2", "3"
  notes            String?
  tenantId         String?           @map("tenant_id") @db.Uuid
  tenant           Tenant?           @relation(fields: [tenantId], references: [id])
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  productionRecipe ProductionRecipe?
  orderItems       OrderItem[]

  @@map("rolls")
}

model ProductionRecipe {
  id           String    @id @default(uuid()) @db.Uuid
  rollId       String    @unique @map("roll_id") @db.Uuid
  roll         Roll      @relation(fields: [rollId], references: [id], onDelete: Cascade)
  warpYarnId   String    @map("warp_yarn_id") @db.Uuid
  warpYarn     YarnStock @relation("WarpYarn", fields: [warpYarnId], references: [id])
  weftYarnId   String    @map("weft_yarn_id") @db.Uuid
  weftYarn     YarnStock @relation("WeftYarn", fields: [weftYarnId], references: [id])
  warpKg       Decimal   @map("warp_kg") @db.Decimal(10, 2)
  weftKg       Decimal   @map("weft_kg") @db.Decimal(10, 2)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("production_recipes")
}

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  orderNumber  String      @unique @map("order_number")
  customerId   String      @map("customer_id") @db.Uuid
  customer     Account     @relation(fields: [customerId], references: [id])
  status       String      @default("draft") // "draft", "confirmed", "invoiced", "cancelled"
  notes        String?
  totalAmount  Decimal     @default(0) @map("total_amount") @db.Decimal(12, 2)
  tenantId     String?     @map("tenant_id") @db.Uuid
  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  orderItems   OrderItem[]
  invoices     Invoice[]

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rollId     String   @unique @map("roll_id") @db.Uuid // unique: bir top yalnız bir siparişte
  roll       Roll     @relation(fields: [rollId], references: [id])
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("order_items")
}

model Invoice {
  id               String               @id @default(uuid()) @db.Uuid
  invoiceNumber    String               @unique @map("invoice_number")
  orderId          String?              @map("order_id") @db.Uuid
  order            Order?               @relation(fields: [orderId], references: [id])
  customerId       String               @map("customer_id") @db.Uuid
  customer         Account              @relation(fields: [customerId], references: [id])
  issueDate        DateTime             @map("issue_date")
  dueDate          DateTime?            @map("due_date")
  subtotal         Decimal              @db.Decimal(12, 2)
  taxRate          Decimal              @default(20) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount        Decimal              @map("tax_amount") @db.Decimal(12, 2)
  totalAmount      Decimal              @map("total_amount") @db.Decimal(12, 2)
  status           String               @default("draft") // "draft", "sent", "paid", "cancelled"
  notes            String?
  filePath         String?              @map("file_path") // Cloud Storage path
  tenantId         String?              @map("tenant_id") @db.Uuid
  tenant           Tenant?              @relation(fields: [tenantId], references: [id])
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  invoiceItems     InvoiceItem[]
  financialTransactions FinancialTransaction[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("invoice_items")
}

model FinancialTransaction {
  id              String    @id @default(uuid()) @db.Uuid
  accountId       String    @map("account_id") @db.Uuid
  account         Account   @relation(fields: [accountId], references: [id])
  invoiceId       String?   @map("invoice_id") @db.Uuid
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  type            String    // "CHECK", "BILL_OF_EXCHANGE", "CASH", "BANK_TRANSFER"
  direction       String    // "RECEIVABLE", "PAYABLE"
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("TRY")
  dueDate         DateTime? @map("due_date")
  referenceNumber String?   @map("reference_number")
  bankName        String?   @map("bank_name")
  status          String    @default("pending") // "pending", "collected", "paid", "bounced", "cancelled", "endorsed"
  notes           String?
  collectedAt     DateTime? @map("collected_at")
  tenantId        String?   @map("tenant_id") @db.Uuid
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("financial_transactions")
}

model Tenant {
  id           String    @id @default(uuid()) @db.Uuid
  name         String                           // Fabrika adı
  email        String?                          // İletişim e-postası
  phone        String?
  address      String?
  taxOffice    String?   @map("tax_office")
  taxNumber    String?   @map("tax_number")
  iban         String?
  logoUrl      String?   @map("logo_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  users                 User[]
  accounts              Account[]
  yarnStocks            YarnStock[]
  rolls                 Roll[]
  orders                Order[]
  invoices              Invoice[]
  financialTransactions FinancialTransaction[]

  @@map("tenants")
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String   @unique
  password   String
  name       String?
  role       String   @default("ADMIN")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model InviteCode {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @map("code")
  isUsed    Boolean   @default(false) @map("is_used")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("invite_codes")
}
